# Razorpay — copy to .env (gitignored) for local `vercel dev`, and set the SAME
# variables in Vercel > Project Settings > Environment Variables for production.
# The /api serverless functions read these via process.env.
# Never expose RAZORPAY_KEY_SECRET to the frontend or commit real values.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
